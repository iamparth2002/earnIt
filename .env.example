# Database - MongoDB connection string
# For MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/earnit?retryWrites=true&w=majority
# For local MongoDB: mongodb://localhost:27017/earnit
DATABASE_URL="mongodb+srv://username:password@cluster.mongodb.net/earnit?retryWrites=true&w=majority"

# JWT Configuration
# Generate a strong secret: openssl rand -base64 32
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_EXPIRES_IN="14d"

# App Configuration
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"
